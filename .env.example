# Copy this file to .env and fill in your values.
# Hugo reads HUGO_PARAMS_* variables and merges them into .Site.Params.*

# Firebase project config (not secret — safe to expose to the browser)
HUGO_PARAMS_FIREBASE_API_KEY=
HUGO_PARAMS_FIREBASE_AUTH_DOMAIN=
HUGO_PARAMS_FIREBASE_PROJECT_ID=
HUGO_PARAMS_FIREBASE_STORAGE_BUCKET=
HUGO_PARAMS_FIREBASE_MESSAGING_SENDER_ID=
HUGO_PARAMS_FIREBASE_APP_ID=

# Backend API base URL
HUGO_PARAMS_BACKENDURL=http://localhost:8080

# Comma-separated list of emails allowed to sign in (mirrors backend ALLOWED_EMAILS)
HUGO_PARAMS_ALLOWED_EMAILS=you@example.com,other@example.com

# Static data sources (Drive-first, GCS fallback)
HUGO_PARAMS_GCS_DATA_BUCKET=collection-showcase-data
HUGO_PARAMS_DRIVE_FOLDER_ID=19lv9yCm4zWQHxr0K3DI7jBW3fp18b0li
HUGO_PARAMS_DRIVE_API_KEY=  # Google API key with Drive API enabled (can reuse Firebase API key)
